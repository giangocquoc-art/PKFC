# LLM_API_BASE_URL="https://api.openai.com/v1"
# LLM_API_KEY=""
# LLM_MODEL="gpt-4o"

# Optional provider headers
LLM_HTTP_REFERER=""
LLM_APP_TITLE="Agent CaMate"

# External access key for P-KFC API
P_KFC_API_KEY=""

# Admin token for secure configuration actions
ADMIN_TOKEN=""

